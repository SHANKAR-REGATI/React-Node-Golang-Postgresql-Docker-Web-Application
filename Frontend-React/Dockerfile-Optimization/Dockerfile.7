# Pin a Specific base image version for stability
# Use debian for easier build utilities
# Use Separate stage for building the application
# Use Separate stage as base for development and production use cases to optimize for both scenarios
FROM node:25.7.0-bullseye AS build-base

# Set a working directory
WORKDIR /usr/src/app

# Copy only those files needed to install dependencies(better layer caching)
COPY package*.json ./

# Use Cache mount to speed up install of existing dependencies
RUN --mount=type=cache,target=/usr/src/app/.npm \
    npm set cache /usr/src/app/.npm && \
    npm install

# Copy the rest of the application code
COPY . .

# development stage
FROM build-base AS development

EXPOSE 5173

CMD ["npm","run","dev"]

# production stage
FROM build-base AS production

# Build the Application
RUN npm run build

# Use Separate Stage for Deploying the Application
# Use nginx as a lightweight web server to serve the static files generated by the build stage
FROM nginx:alpine

# Copy nginx configuration file
# Use COPY --link to create a hard link instead of copying the file, 
# which can save space and speed up the build process
COPY --link nginx.conf /etc/nginx/conf.d/default.conf

# Copy the build artifact(/dist) from the build stage to nginx's html directory
COPY --link --from=production /usr/src/app/dist /usr/share/nginx/html

# export the port on which nginx will serve the application
EXPOSE 80

# No need to specify CMD as nginx image already has a default CMD["nginx", "-g", "daemon off;"] to start nginx server